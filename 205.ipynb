    "s = 'ejj'\n",
    "t = 'pee'\n",
    "dict = {}\n",
    "out = True\n",
    "if len(s) != len(t) : print False\n",
    "for i in range(len(s)) :\n",
    "    if s[i] not in dict :\n",
    "        if t[i] in dict.values() :\n",
    "            out = False\n",
    "        dict[s[i]] = t[i]\n",
    "    elif dict[s[i]] != t[i] :\n",
    "        out = False\n",
    "print out"
