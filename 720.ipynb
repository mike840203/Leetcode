    "words = [\"a\", \"banana\", \"app\", \"appl\", \"ap\", \"apply\", \"apple\"]\n",
    "words.sort()\n",
    "word_set , longest = set(['']) , ''\n",
    "for word in words :\n",
    "    print word\n",
    "    if word[:-1] in word_set :\n",
    "        word_set.add(word)\n",
    "        if len(word) > len(longest) :\n",
    "            longest = word\n",
    "print longest"
