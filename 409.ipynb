    "        dict[element] = 1\n",
    "    else :\n",
    "        dict[element] = 0\n",
    "        out = out + 1 * 2\n",
    "for element in s :\n",
    "    if dict[element] == 1 :\n",
    "        out = out + 1\n",
    "        break\n",
    "print out"
