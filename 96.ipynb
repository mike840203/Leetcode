    "n = 5\n",
    "table = [1,1]\n",
    "for i in range(2,n+1) :\n",
    "    table.append(0)\n",
    "    for j in range(i) :\n",
    "        table[i] += table[j] * table[i-1-j]\n",
    "print table"
