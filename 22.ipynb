    "def generate(p, left, right):\n",
    "    if right >= left >= 0:\n",
    "        if not right:\n",
    "            yield p\n",
    "        for q in generate(p + '(', left-1, right): yield q\n",
    "        for q in generate(p + ')', left, right-1): yield q\n",
    "n = 3\n",
    "print list(generate('', n, n))"
   ]
