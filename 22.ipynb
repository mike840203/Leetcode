    "def generate(p, left, right, parens=[]):\n",
    "    print left , right\n",
    "    if left:         generate(p + '(', left-1, right)\n",
    "    if right > left: generate(p + ')', left, right-1)\n",
    "    if not right:    \n",
    "        parens += p,\n",
    "        print \"\"\n",
    "    return parens\n",
    "n= 3\n",
    "print generate('', n, n)\n"
   ]
