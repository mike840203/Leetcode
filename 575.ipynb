    "candies = [1,1,2,3]\n",
    "dict = {}\n",
    "for i in candies :\n",
    "    if i not in dict :\n",
    "        dict[i] = 1\n",
    "    else :\n",
    "        dict[i] += 1\n",
    "print len(dict.keys()) if len(dict.keys()) <= len(candies) / 2 else len(candies) / 2\n",
    "        "
