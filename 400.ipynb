    "n = 209\n",
    "i = 1\n",
    "while n > i * ( 10 ** (i-1) ) * 9 :\n",
    "    n = n - i * ( 10 ** (i-1) ) * 9\n",
    "    i += 1\n",
    "devide = n / ( i * ( 10 ** (i-1) ) )\n",
    "percen = n % ( i * ( 10 ** (i-1) ) )\n",
    "print i\n",
    "print ( i * ( 10 ** (i-1) ) )\n",
    "print n\n",
    "print devide , percen\n"
