    "ma = 1 \n",
    "temp = 1\n",
    "length = len(nums)\n",
    "if length == 0 : print 0\n",
    "for i in range(length-1) :\n",
    "    if nums[i] < nums[i+1] :\n",
    "        temp = temp + 1\n",
    "    if nums[i] >= nums[i+1] or i == length -2 : \n",
    "        ma = max(temp,ma)\n",
    "        temp = 1\n",
    "print ma"
