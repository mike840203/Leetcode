   "source": [
    "height = [2,5,8,6,4,8,2,3,5,7]\n",
    "head , tail = 0 , len(height) -1\n",
    "ma = 0 \n",
    "while head < tail :\n",
    "    ma = max(ma, (tail-head) * min(height[head],height[tail]) )\n",
    "    if height[head] > height[tail] :\n",
    "        tail -= 1\n",
    "    else :\n",
    "        head += 1 \n",
    "print ma"
   ]
