   "source": [
    "houses = [1,2,3]\n",
    "heaters = [2]\n",
    "maxdistant = 0\n",
    "if len(heaters) == 1 :\n",
    "    print max(int(heaters[0])-houses[0],houses[-1]-int(heaters[0]))\n",
    "for i in range(len(heaters)-1) :\n",
    "    maxdistant = max(maxdistant,heaters[i+1]-heaters[i]-1)\n",
    "print maxdistant / 2"
   ]
