    "nums = [1, 2, 3, 4]\n",
    "index = 0\n",
    "num = 0\n",
    "for i in range(len(nums)) :\n",
    "    if nums[i] == max(nums) :\n",
    "        index = i\n",
    "num = nums[index]\n",
    "nums[index] = 0\n",
    "if max(nums) * 2 <= num :\n",
    "    print index\n",
    "else :\n",
    "    print -1"
