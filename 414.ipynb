    "nums.sort()\n",
    "i = 1\n",
    "for element in range(len(nums)-1,0,-1) :\n",
    "    if nums[element] != nums[element-1] :\n",
    "        i = i + 1\n",
    "    if i == 3 :\n",
    "        print nums[element-1]\n",
    "        break\n",
    "if i != 3 :\n",
    "    print nums[-1]"
