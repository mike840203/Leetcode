    "def addDigits(num):\n",
    "    num = str(num)\n",
    "    temp = 0\n",
    "    for element in num :\n",
    "        temp = temp + int(element)\n",
    "    if temp < 10 :\n",
    "        return temp\n",
    "    else :\n",
    "        return addDigits(temp)\n",
    "addDigits(38)"
   ]
