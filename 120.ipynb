   "source": [
    "triangle = [[2],[3,4],[6,5,7],[4,1,8,3]]\n",
    "out = [0] * (len(triangle) + 1)\n",
    "for row in triangle[::-1] :\n",
    "    for index in range(len(row)) :\n",
    "        out[index] = row[index] + min(out[index],out[index+1])\n",
    "print out[0]"
   ]
