   "source": [
    "nums = [1,1,0,1,1,1]\n",
    "ma = 0 \n",
    "temp = 0\n",
    "for i in range(len(nums)) :\n",
    "    if nums[i] == 1 :\n",
    "        temp = temp + 1 \n",
    "    if nums[i] == 0 or i == len(nums) - 1 :\n",
    "        ma = max(ma,temp)\n",
    "        temp = 0\n",
    "print ma"
   ]
