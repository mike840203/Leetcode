   "source": [
    "num = 10\n",
    "out = [0]\n",
    "offset = 1\n",
    "for i in range(1,num+1) :\n",
    "    if offset * 2 == i :\n",
    "        offset *= 2 \n",
    "    out.append(out[i-offset]+1)\n",
    "print out"
   ]
