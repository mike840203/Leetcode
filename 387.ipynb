   "source": [
    "s = \"CCCC\"\n",
    "dict = {}\n",
    "for i in range(len(s)) :\n",
    "    if s[i] not in dict :\n",
    "        dict[s[i]] = i\n",
    "    else :\n",
    "        dict[s[i]] = -1\n",
    "mi = -1000000\n",
    "for key in dict :\n",
    "    if dict[key] > -1 :\n",
    "        mi = min(abs(mi),dict[key])\n",
    "if mi == -1000000 :\n",
    "    mi = -1\n",
    "print mi\n",
    "    "
   ]
